# ===========================
# NeuraBot AI — .gitignore
# ===========================

# Maven build output
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# Maven dependency-reduced pom (generated by shade plugin)
dependency-reduced-pom.xml

# IDE files — IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/

# IDE files — Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# IDE files — VS Code
.vscode/

# IDE files — NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Application data (user-specific, not for version control)
# These are generated at runtime in the user's home directory
# ~/.neurabot/ is already outside the project folder

# Log files
*.log
logs/

# Compiled Java class files
*.class

# Package files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Windows batch file artifacts
*.tmp

# JVM crash logs
hs_err_pid*
replay_pid*
